{
  "name": "opencode-chat-unofficial",
  "displayName": "opencode chat",
  "description": "opencode chat extension for the IDE",
  "repository": "https://github.com/kwickramasekara/opencode-chat",
  "publisher": "kwickramasekara",
  "version": "2.4.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./out/main.js",
  "contributes": {
    "commands": [
      {
        "command": "opencode.addToChat",
        "title": "opencode: Add to Chat",
        "icon": "$(add)"
      },
      {
        "command": "opencode.toggleChatView",
        "title": "opencode: Toggle Chat View"
      },
      {
        "command": "opencode.restart",
        "title": "opencode: Restart"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "opencode.addToChat",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "opencode.addToChat",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-sidebar",
          "title": "opencode",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "opencode-sidebar": [
        {
          "type": "webview",
          "id": "opencode.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "opencode",
      "properties": {
        "opencode.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Fixed port for the opencode server. Set to 0 (default) to use a random port. Note: changing the port resets preferences stored in the webview (e.g. theme) since they are tied to the origin."
        },
        "opencode.exposeToNetwork": {
          "type": "boolean",
          "default": false,
          "description": "Expose the opencode server to the local network via mDNS. When enabled, you can access the same instance from another device at http://opencode.local:<port>."
        }
      }
    }
  },
  "scripts": {
    "copy-templates": "mkdir -p out/webview/templates && cp src/webview/templates/*.html out/webview/templates/",
    "compile": "tsc -p ./ && npm run copy-templates",
    "publish": "npm run compile && vsce publish && ovsx publish",
    "watch": "npm run copy-templates && tsc -w -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
